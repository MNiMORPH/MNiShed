# Dakota input file: MNiShed Cannon River Bayesian (DREAM) calibration
# Generated by `generate_dakota_in.py --bayes` from params.yml — do not edit.
#
# Active parameters (9) with uniform priors over their bounds:
#   log__t_recession_shallow: log10 shallow/interflow e-folding time [days]
#   log__t_recession_soil: log10 soil-zone e-folding time [days]
#   log__t_recession_karst: log10 karst/bedrock e-folding time [days]
#   f_exfiltration_shallow: fraction of shallow exfiltration to stream (remainder recharges soil)
#   f_exfiltration_soil: fraction of soil-zone exfiltration to stream (remainder recharges karst)
#   PDD_melt_factor: degree-day snowmelt rate [mm SWE / degC / day]
#   log__Hmax_shallow: log10 shallow-reservoir max effective depth [mm]; saturation-excess OLF when exceeded
#   log__fdd_threshold: log10 frozen-ground-index threshold [degC·day]; blocks shallow-to-soil infiltration
#   log__routing_K: log10 Nash-cascade storage time constant [days] (N=2; mean travel time = N*K)
# Fixed (inactive) parameters:
#   snow_insulation_k = 0.0  (snow insulation decay constant [mm⁻¹ SWE]; T_eff = T·exp(-k·SWE); 0 = off)
#   f_direct_runoff = 0.0  (fast-bypass fraction of daily recharge; Hortonian-inspired but not rigorous at daily scale)
#
# Likelihood: Gaussian on the 1096 scored log-flow residuals
# (driver_bayes.py returns modelled log-flows; cannon_logq_obs.dat holds the
# observed log-flows); the error scale is inferred (calibrate_error_multipliers).

environment
  tabular_data
    tabular_data_file = 'dakota_bayes.dat'

method
  bayes_calibration dream
    chain_samples = 20000
    seed = 12345
    calibrate_error_multipliers one
  model_pointer = 'M1'

model
  id_model = 'M1'
  single
    interface_pointer = 'I1'
  variables_pointer = 'V1'
  responses_pointer = 'R1'

variables
  id_variables = 'V1'
  uniform_uncertain = 9
    descriptors   = 'log__t_recession_shallow' 'log__t_recession_soil' 'log__t_recession_karst' 'f_exfiltration_shallow' 'f_exfiltration_soil' 'PDD_melt_factor' 'log__Hmax_shallow' 'log__fdd_threshold' 'log__routing_K'
    lower_bounds  =  0.3  1.0  2.5  0.01  0.01  0.1  1.0  0.0  -1.0
    upper_bounds  =  2.0  2.7  4.5  0.99  0.99  10.0  3.5  3.0  1.0
    initial_point =  1.2  1.8  3.5  0.8  0.1  1.0  2.3  1.0  0.0

interface
  id_interface = 'I1'
  analysis_driver = 'bash run_driver_bayes.sh'
  fork
    parameters_file = 'params.in'
    results_file    = 'results.out'
    work_directory
      named 'out_bayes/run'
      directory_tag
      directory_save
    file_save
    copy_files 'driver_bayes.py' 'cannon_cfg_template.yml' 'CannonTestInput.csv' 'run_driver_bayes.sh' 'params.yml' 'cannon_logq_obs.dat'
    asynchronous
      evaluation_concurrency = 4

responses
  id_responses = 'R1'
  calibration_terms = 1096
    calibration_data_file = 'cannon_logq_obs.dat'
      freeform
  no_gradients
  no_hessians
